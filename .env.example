# EClaw Channel API
ECLAW_API_BASE=https://eclawbot.com
ECLAW_API_KEY=eck_your_channel_api_key
ECLAW_API_SECRET=
ECLAW_WEBHOOK_URL=https://your-public-url.example.com
ECLAW_WEBHOOK_PORT=18800
ECLAW_BOT_NAME=Codex
ECLAW_ENTITY_ID=
ECLAW_CALLBACK_TOKEN=
ECLAW_CALLBACK_USERNAME=
ECLAW_CALLBACK_PASSWORD=

# Codex runtime
CODEX_BIN=codex
CODEX_WORKSPACE=/absolute/path/to/your/project
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=on-request
CODEX_APP_SERVER_LISTEN=ws://127.0.0.1:0
CODEX_REASONING_EFFORT=
CODEX_REPORT_MODEL=GPT-5.5
CODEX_REPORT_REASONING=extrahigh
CODEX_POLL_BRIDGE_BYPASS_APPROVALS=false
CODEX_POLL_BRIDGE_TIMEOUT_MS=1200000
CODEX_POLL_BRIDGE_NEAR_TIMEOUT_WARNING_MS=900000
CODEX_POLL_BRIDGE_NEAR_TIMEOUT_CANCEL_MS=1080000
CODEX_POLL_BRIDGE_TERMINATE_GRACE_MS=120000
CODEX_POLL_BRIDGE_DIAGNOSTIC_LOG=.data/codex-exec-diagnostics.jsonl
BUSY_HEARTBEAT_DISABLED=false
CODEX_POLL_BRIDGE_STATUS_UPDATES=false
CODEX_POLL_BRIDGE_STATUS_INITIAL_MS=30000
CODEX_POLL_BRIDGE_STATUS_MS=180000

# Bridge behavior
BRIDGE_STATE_PATH=.data/state.json
BRIDGE_PUBLIC_BASE_URL=
BRIDGE_REPLY_TIMEOUT_MS=600000
BRIDGE_APPROVAL_TIMEOUT_MS=900000
BRIDGE_SEND_BUSY_UPDATES=false
BRIDGE_STATUS_HEARTBEAT_ENABLED=false
BRIDGE_STATUS_HEARTBEAT_MS=180000
BRIDGE_REQUIRE_CALLBACK_AUTH=false

# Phase 2: channel key path via /api/transform (requires channel registration)
ECLAW_PREFER_TRANSFORM_VIA_CHANNEL_KEY=false
